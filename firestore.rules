rules_version = '2';

// Firestore rules for the shared `price-my-print` project.
// Covers Price My Print, QuoteBench and SpoolTrack.
//
// Note: `match /users/{uid}` matches ONLY that document — Firestore does not
// cascade rules into subcollections. SpoolTrack stores spools and barcode
// aliases in subcollections under the user, so they need the explicit nested
// matches below; without them every write is denied by default.

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      // Price My Print — data stored on the user document itself.
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // ── SpoolTrack ────────────────────────────────────────────────
      // One document per physical spool.
      match /spools/{spoolId} {
        allow read, delete: if stIsOwner(uid);
        allow create, update: if stIsOwner(uid) && stValidSpool();
      }

      // Learned barcode → filament bindings, keyed by the normalised
      // barcode so a rescan is a single direct read.
      match /aliases/{code} {
        allow read, delete: if stIsOwner(uid);
        allow create, update: if stIsOwner(uid)
                              && code.size() > 0 && code.size() <= 64
                              && request.resource.data.keys().size() <= 25;
      }
    }

    match /quotebench/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    function stIsOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Validated so a compromised client can't write junk or balloon a doc.
    function stValidSpool() {
      let d = request.resource.data;
      return d.keys().size() <= 30
          && d.brand is string    && d.brand.size()    <= 120
          && d.color is string    && d.color.size()    <= 200
          && d.material is string && d.material.size() <= 60
          && d.hex is string      && d.hex.matches('^#[0-9a-fA-F]{6}$')
          && (d.cost == null || (d.cost is number && d.cost >= 0 && d.cost <= 100000))
          && d.status in ['sealed', 'open', 'empty']
          && (d.notes == null  || (d.notes is string  && d.notes.size()  <= 2000))
          && (d.vendor == null || (d.vendor is string && d.vendor.size() <= 200));
    }
  }
}
